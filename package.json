{
  "name": "estif-home-1000x",
  "version": "1.0.0",
  "description": "Enterprise Smart Home Control System - Complete IoT Solution with AI, Automation, and Real-time Control",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "monitor": "node scripts/monitor.js",
    "seed": "node database/seeds/seed.js",
    "migrate": "node database/migrate.js",
    "pm2:start": "pm2 start server.js --name estif-home",
    "pm2:stop": "pm2 stop estif-home",
    "pm2:restart": "pm2 restart estif-home",
    "pm2:logs": "pm2 logs estif-home"
  },
  "keywords": [
    "smart-home",
    "iot",
    "esp32",
    "automation",
    "ai",
    "machine-learning",
    "home-automation",
    "real-time",
    "websocket",
    "nodejs"
  ],
  "author": "Estif Home Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "socket.io": "^4.5.4",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "express-rate-limit": "^7.1.5",
    "morgan": "^1.10.0",
    "winston": "^3.11.0",
    "node-cron": "^3.0.3",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.1",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "speakeasy": "^2.0.0",
    "nodemailer": "^6.9.7",
    "twilio": "^4.20.0",
    "mqtt": "^5.3.4",
    "redis": "^4.6.11",
    "mongoose": "^8.0.3",
    "sqlite3": "^5.1.6",
    "sequelize": "^6.35.1",
    "@tensorflow/tfjs-node": "^4.15.0",
    "natural": "^6.11.1",
    "csv-parser": "^3.0.0",
    "fast-csv": "^4.3.6",
    "archiver": "^6.0.1",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "pm2": "^5.3.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/johnsonestif12/estif-home-1000x.git"
  },
  "bugs": {
    "url": "https://github.com/johnsonestif12/estif-home-1000x/issues"
  },
  "homepage": "https://github.com/johnsonestif12/estif-home-1000x#readme"
}